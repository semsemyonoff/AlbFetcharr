# Copy to .env and adjust. Consumed by docker-compose.yml — both for compose
# interpolation (image/tag/port/paths) and as the container's env_file (every
# variable below is passed into the container). Lines you leave blank/remove
# fall back to the image defaults.

# ─────────────────────────────────────────────────────────────────────────────
# Deployment (compose interpolation)
# ─────────────────────────────────────────────────────────────────────────────

# Published image + tag to run. Pin to a release (e.g. 1.0.0) in production;
# `latest` is fine for trying it out.
ALBFETCHARR_IMAGE=semsemyonoff/albfetcharr
ALBFETCHARR_TAG=latest

# Host port the UI/API is exposed on (the container always serves on 5000).
ALBFETCHARR_HTTP_PORT=8080

# Host paths bind-mounted into the container.
#   config/    — persistent app state: settings DB + optional oauth/cookies (/config)
#   downloads/ — download staging dir, shared with Lidarr (/downloads)
#   library/   — your Lidarr root folder, for cover-art copy (/libraries/music)
ALBFETCHARR_CONFIG_DIR=./config
ALBFETCHARR_DOWNLOADS_DIR=./downloads
ALBFETCHARR_LIBRARY_DIR=./library

# Container timezone (affects logs / timestamps).
TZ=UTC

# ─────────────────────────────────────────────────────────────────────────────
# Required app configuration
# ─────────────────────────────────────────────────────────────────────────────

# Lidarr connection — where AlbFetcharr reads the wanted list and triggers imports.
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=

# Yandex Music auth token (the most accurate source). See:
# https://yandex-music.readthedocs.io/en/main/token.html
YANDEX_MUSIC_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Lidarr import wiring (paths AS LIDARR SEES THEM)
# ─────────────────────────────────────────────────────────────────────────────

# Download staging dir in Lidarr's path namespace (used for ManualImport).
ALBFETCHARR_LIDARR_IMPORT_PATH=/data/downloads/alb

# Map each Lidarr root folder to its path inside AlbFetcharr (for cover-art copy):
#   <lidarr_path>=<albfetcharr_path>[,<lidarr_path2>=<albfetcharr_path2>...]
ALBFETCHARR_LIBRARY_MAP=/data/library=/libraries/music

# ─────────────────────────────────────────────────────────────────────────────
# Optional — settings persistence & secrets at rest
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key encrypting secrets (tokens, API keys) in the settings DB. Without it
# the app runs env-only (secret writes to the DB are refused). Generate one with:
#   python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# WARNING: back this up — if lost, encrypted secrets cannot be recovered.
ALBFETCHARR_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Optional — common tweaks (see the README "Environment variables" reference)
# ─────────────────────────────────────────────────────────────────────────────

# Yandex download quality: 0 = AAC 64, 1 = AAC 192, 2 = FLAC.
YANDEX_MUSIC_QUALITY=2

# UI defaults.
# ALBFETCHARR_DEFAULT_LANG=en
# ALBFETCHARR_DEFAULT_THEME=system

# Source toggles (1/true/yes = on, 0/false/no = off).
# ALBFETCHARR_ENABLE_YANDEX=1
# ALBFETCHARR_ENABLE_YOUTUBE_MUSIC=1
# ALBFETCHARR_ENABLE_SOUNDCLOUD=1

# YouTube cookies / OAuth (paths INSIDE the container, under /config). See README.
# ALBFETCHARR_YTDLP_COOKIES=/config/cookies.txt
# ALBFETCHARR_YTMUSIC_OAUTH=/config/ytmusic_oauth.json
